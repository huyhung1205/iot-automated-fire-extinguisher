<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý Thông báo"
                style="@style/TextAppearance.SmartFireMonitoring.Hero" />
        </LinearLayout>

        <!-- Main Alert Toggle Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            style="@style/Widget.SmartFireMonitoring.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHO PHÉP CẢNH BÁO"
                        style="@style/TextAppearance.SmartFireMonitoring.Label" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4"
                        android:text="Bật/tắt toàn bộ luồng cảnh báo"
                        style="@style/TextAppearance.SmartFireMonitoring.MutedBody" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAlertEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/primary"
                    app:trackTint="@color/info_soft" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Snooze Control Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            style="@style/Widget.SmartFireMonitoring.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chế độ tạm tắt (Snooze)"
                    style="@style/TextAppearance.SmartFireMonitoring.Label"
                    android:layout_marginBottom="@dimen/spacing_16"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_16"
                    android:hint="Thời gian tạm ngưng (phút)"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_alarm"
                    app:startIconTint="@color/primary"
                    style="@style/Widget.SmartFireMonitoring.InputLayout">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSnoozeDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="10" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSnooze"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_min_height"
                        android:layout_weight="1.5"
                        android:layout_marginEnd="@dimen/spacing_8"
                        android:text="TẠM TẮT"
                        app:cornerRadius="@dimen/button_corner_radius"
                        style="@style/Widget.SmartFireMonitoring.Button.Primary" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetSnooze"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_min_height"
                        android:layout_weight="1"
                        android:text="RESET"
                        app:cornerRadius="@dimen/button_corner_radius"
                        style="@style/Widget.SmartFireMonitoring.Button.Secondary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:gravity="center"
                    android:background="@color/warning_soft"
                    android:padding="@dimen/spacing_12"
                    android:text="⏱️ Đang tạm tắt: còn --:--"
                    android:textColor="@color/warning"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Last Trigger Event Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            app:cardBackgroundColor="@color/danger_soft"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/danger"
            app:cardCornerRadius="@dimen/card_corner_radius">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_16"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phát hiện gần nhất"
                    style="@style/TextAppearance.SmartFireMonitoring.Label"
                    android:textColor="@color/danger" />
                <TextView
                    android:id="@+id/tvLastTriggered"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:text="Chưa có dữ liệu sự cố"
                    android:textColor="@color/danger"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
