<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fireAlertOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6DC2626"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:maxWidth="420dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <FrameLayout
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_marginBottom="24dp">

                    <View
                        android:id="@+id/fireAlertPulseCircle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_fire_alert_circle" />

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_flame"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvFireAlertTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CẢNH BÁO CHÁY!"
                    android:textColor="@color/danger"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tvFireAlertMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Phát hiện nguy cơ cháy\ntại khu vực giám sát!"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginVertical="20dp" />

                <TextView
                    android:id="@+id/tvFireAlertTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian: 14:30:05"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFireAlertClose"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_min_height"
                    android:layout_marginTop="24dp"
                    android:text="XÁC NHẬN &amp; ĐÓNG"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/danger"
                    app:cornerRadius="@dimen/button_corner_radius"
                    style="@style/Widget.SmartFireMonitoring.Button.Primary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Hệ thống đang tự động kích hoạt vòi phun"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:alpha="0.8" />

    </LinearLayout>

</FrameLayout>
