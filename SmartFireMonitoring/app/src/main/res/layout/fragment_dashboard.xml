<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xlarge">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/headerActionCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Home Dashboard"
                    style="@style/TextAppearance.SmartFireMonitoring.Hero" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerActionCard"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="@color/primary" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Connection Alert Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bannerConnection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:visibility="gone"
            app:cardBackgroundColor="@color/warning_soft"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_medium">

                <ImageView
                    android:layout_width="@dimen/icon_size_std"
                    android:layout_height="@dimen/icon_size_std"
                    android:src="@android:drawable/stat_sys_warning"
                    app:tint="@color/warning" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:text="Mất kết nối — Đang hiển thị dữ liệu cũ"
                    style="@style/TextAppearance.SmartFireMonitoring.Label"
                    android:textColor="@color/warning" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Core System Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            style="@style/Widget.SmartFireMonitoring.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/eye_status_green" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_medium"
                        android:layout_weight="1"
                        android:text="Thiết bị: Trực tuyến"
                        style="@style/TextAppearance.SmartFireMonitoring.ScreenTitle"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvFirmwareVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fimware: 2.2.0"
                        style="@style/TextAppearance.SmartFireMonitoring.Caption" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/spacing_large"
                    android:background="@color/border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRẠNG THÁI"
                            style="@style/TextAppearance.SmartFireMonitoring.Label" />

                        <TextView
                            android:id="@+id/tvEsp32Power"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_tiny"
                            android:text="Đang hoạt động"
                            style="@style/TextAppearance.SmartFireMonitoring.Body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PHẢN HỒI"
                            style="@style/TextAppearance.SmartFireMonitoring.Label" />

                        <TextView
                            android:id="@+id/tvHeartbeatStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_tiny"
                            android:text="2s trước"
                            style="@style/TextAppearance.SmartFireMonitoring.Body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:text="Cảm biến môi trường"
            style="@style/TextAppearance.SmartFireMonitoring.ScreenTitle" />

        <!-- Sensor Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="false">

            <!-- Temperature Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="@dimen/spacing_tiny"
                android:layout_marginBottom="@dimen/spacing_large"
                style="@style/Widget.SmartFireMonitoring.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <ImageView
                        android:layout_width="@dimen/icon_size_card"
                        android:layout_height="@dimen/icon_size_card"
                        android:src="@drawable/ic_temp"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:text="Nhiệt độ"
                        style="@style/TextAppearance.SmartFireMonitoring.CardTitle" />

                    <TextView
                        android:id="@+id/tvTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        style="@style/TextAppearance.SmartFireMonitoring.SensorValue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Humidity Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="@dimen/spacing_tiny"
                android:layout_marginBottom="@dimen/spacing_large"
                style="@style/Widget.SmartFireMonitoring.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <ImageView
                        android:layout_width="@dimen/icon_size_card"
                        android:layout_height="@dimen/icon_size_card"
                        android:src="@drawable/ic_humidity"
                        app:tint="@color/accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:text="Độ ẩm"
                        style="@style/TextAppearance.SmartFireMonitoring.CardTitle" />

                    <TextView
                        android:id="@+id/tvHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        style="@style/TextAppearance.SmartFireMonitoring.SensorValue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gas / Smoke Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mq2Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_columnSpan="2"
                android:layout_marginBottom="@dimen/spacing_large"
                style="@style/Widget.SmartFireMonitoring.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <ImageView
                        android:layout_width="@dimen/icon_size_hero"
                        android:layout_height="@dimen/icon_size_hero"
                        android:background="@color/warning_soft"
                        android:padding="8dp"
                        android:src="@drawable/ic_gas"
                        app:tint="@color/warning" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_large"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KHÍ GAS / KHÓI (MQ-2)"
                            style="@style/TextAppearance.SmartFireMonitoring.CardTitle" />

                        <TextView
                            android:id="@+id/tvMq2Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- ADC"
                            style="@style/TextAppearance.SmartFireMonitoring.SensorValue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMq2Level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_info"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4"
                        android:text="AN TOÀN"
                        style="@style/TextAppearance.SmartFireMonitoring.Label"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Flame Sensor Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_columnSpan="2"
                android:layout_marginBottom="@dimen/spacing_xlarge"
                style="@style/Widget.SmartFireMonitoring.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="@dimen/icon_size_std"
                            android:layout_height="@dimen/icon_size_std"
                            android:src="@drawable/ic_flame"
                            app:tint="@color/danger" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:layout_weight="1"
                            android:text="PHÁT HIỆN LỬA"
                            style="@style/TextAppearance.SmartFireMonitoring.CardTitle" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xlarge"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/eye1"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginHorizontal="@dimen/spacing_small"
                            android:background="@drawable/eye_status_green" />

                        <View
                            android:id="@+id/eye2"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginHorizontal="@dimen/spacing_small"
                            android:background="@drawable/eye_status_green" />

                        <View
                            android:id="@+id/eye3"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginHorizontal="@dimen/spacing_small"
                            android:background="@drawable/eye_status_green" />

                        <View
                            android:id="@+id/eye4"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginHorizontal="@dimen/spacing_small"
                            android:background="@drawable/eye_status_green" />

                        <View
                            android:id="@+id/eye5"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginHorizontal="@dimen/spacing_small"
                            android:background="@drawable/eye_status_green" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDirection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="center"
                        android:text="Hướng lửa: CENTER"
                        style="@style/TextAppearance.SmartFireMonitoring.Label" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:text="Thiết bị chấp hành"
            style="@style/TextAppearance.SmartFireMonitoring.ScreenTitle" />

        <!-- Actuators Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_huge"
            style="@style/Widget.SmartFireMonitoring.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MÁY BƠM"
                            style="@style/TextAppearance.SmartFireMonitoring.Label" />

                        <TextView
                            android:id="@+id/tvPump"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_tiny"
                            android:text="TẮT"
                            style="@style/TextAppearance.SmartFireMonitoring.Body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/border" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CÒI BÁO"
                            style="@style/TextAppearance.SmartFireMonitoring.Label" />

                        <TextView
                            android:id="@+id/tvBuzzer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_tiny"
                            android:text="TẮT"
                            style="@style/TextAppearance.SmartFireMonitoring.Body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/spacing_large"
                    android:background="@color/border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvServoX"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Servo X: 90°"
                        style="@style/TextAppearance.SmartFireMonitoring.Caption" />

                    <TextView
                        android:id="@+id/tvServoY"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="Servo Y: 45°"
                        style="@style/TextAppearance.SmartFireMonitoring.Caption" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
