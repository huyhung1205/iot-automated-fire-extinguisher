<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thiết lập Ngưỡng"
                style="@style/TextAppearance.SmartFireMonitoring.Hero" />
        </LinearLayout>

        <!-- Current Configuration Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            app:cardBackgroundColor="@color/info_soft"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="@dimen/card_corner_radius">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cấu hình hiện tại trên ESP32"
                    style="@style/TextAppearance.SmartFireMonitoring.Label"
                    android:textColor="@color/primary" />
                <TextView
                    android:id="@+id/tvCurrentThresholds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="Đang tải dữ liệu..."
                    style="@style/TextAppearance.SmartFireMonitoring.Body"
                    android:textColor="@color/primary_variant"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- MQ-2 Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            style="@style/Widget.SmartFireMonitoring.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khí gas / khói (MQ-2)"
                    style="@style/TextAppearance.SmartFireMonitoring.CardTitle"
                    android:layout_marginBottom="@dimen/spacing_16"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_12"
                    android:hint="Ngưỡng An toàn (ADC)"
                    app:startIconDrawable="@drawable/ic_gas"
                    app:startIconTint="@color/primary"
                    style="@style/Widget.SmartFireMonitoring.InputLayout">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMq2Safe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textSize="@dimen/text_size_body" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ngưỡng Cảnh báo (ADC)"
                    app:startIconDrawable="@drawable/ic_gas"
                    app:startIconTint="@color/warning"
                    style="@style/Widget.SmartFireMonitoring.InputLayout">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMq2Warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textSize="@dimen/text_size_body" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Temperature Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            style="@style/Widget.SmartFireMonitoring.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhiệt độ môi trường"
                    style="@style/TextAppearance.SmartFireMonitoring.CardTitle"
                    android:layout_marginBottom="@dimen/spacing_16"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_12"
                    android:hint="Ngưỡng An toàn (°C)"
                    app:startIconDrawable="@drawable/ic_temp"
                    app:startIconTint="@color/primary"
                    style="@style/Widget.SmartFireMonitoring.InputLayout">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTempSafe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textSize="@dimen/text_size_body" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ngưỡng Cảnh báo (°C)"
                    app:startIconDrawable="@drawable/ic_temp"
                    app:startIconTint="@color/warning"
                    style="@style/Widget.SmartFireMonitoring.InputLayout">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTempWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textSize="@dimen/text_size_body" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveThresholds"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_min_height"
            android:layout_marginBottom="@dimen/spacing_24"
            android:text="Lưu cấu hình"
            style="@style/Widget.SmartFireMonitoring.Button.Primary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
