<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEventRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEventTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔥 16/05 14:32"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/body_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEventLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/chip_safe_bg"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingVertical="4dp"
                android:text="DANGER"
                android:textColor="@color/safe_green"
                android:textSize="@dimen/caption_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvEventTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Nhiệt: 55.2°C | MQ2: 1823"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/body_text_size" />

        <TextView
            android:id="@+id/tvEventDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Hướng: center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/body_text_size" />

        <TextView
            android:id="@+id/tvEventPattern"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pattern: 00100"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/body_text_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEventAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/chip_info_bg"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingVertical="6dp"
                android:text="Xử lý: auto"
                android:textColor="@color/primary"
                android:textSize="@dimen/caption_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEventDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@color/surface_variant"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingVertical="6dp"
                android:text="Thời gian: 2m"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/caption_text_size"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
