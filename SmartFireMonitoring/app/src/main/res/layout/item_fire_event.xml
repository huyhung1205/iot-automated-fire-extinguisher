<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEventRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_12"
    style="@style/Widget.SmartFireMonitoring.Card.Compact">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_16">

        <!-- Indicator line -->
        <View
            android:id="@+id/viewIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/danger"
            android:layout_marginEnd="@dimen/spacing_16"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEventTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="16/05 14:32"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEventLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_8"
                    android:paddingVertical="2dp"
                    android:background="@color/danger_soft"
                    android:text="LỬA"
                    android:textColor="@color/danger"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvEventTemperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:text="Nhiệt: 55.2°C | Gas: 1823"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEventDirection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hướng: CENTER"
                    style="@style/Widget.SmartFireMonitoring.StatusChip"
                    android:textSize="12sp"/>

                <View android:layout_width="1dp" android:layout_height="10dp" android:background="@color/border" android:layout_marginHorizontal="@dimen/spacing_8" android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvEventDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kéo dài: 2m"
                    style="@style/Widget.SmartFireMonitoring.StatusChip"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Hidden details for logic compatibility if needed -->
            <TextView android:id="@+id/tvEventPattern" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvEventAction" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/border"
            android:rotation="0"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
