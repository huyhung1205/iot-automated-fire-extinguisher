<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding"
    tools:context=".HistoryFragment">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_24"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lịch sử Sự kiện"
            style="@style/TextAppearance.SmartFireMonitoring.Hero" />
    </LinearLayout>

    <!-- Summary & Toggle Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_large"
        style="@style/Widget.SmartFireMonitoring.Card">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/card_padding"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvHistoryCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 sự kiện"
                    style="@style/TextAppearance.SmartFireMonitoring.ScreenTitle"
                    android:textSize="@dimen/text_size_section" />
                <ImageView
                    android:layout_width="@dimen/icon_size_standard"
                    android:layout_height="@dimen/icon_size_standard"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/primary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleHistoryView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                app:checkedButton="@id/btnHistoryList"
                app:selectionRequired="true"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistoryList"
                    style="@style/Widget.SmartFireMonitoring.Button.Toggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Danh sách"
                    android:textSize="13sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistoryChart"
                    style="@style/Widget.SmartFireMonitoring.Button.Toggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Biểu đồ"
                    android:textSize="13sp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_24"
            tools:listitem="@layout/item_fire_event" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/surface"
            android:layout_marginBottom="@dimen/spacing_24" />

        <TextView
            android:id="@+id/tvHistoryEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Không có dữ liệu lịch sử"
            style="@style/TextAppearance.SmartFireMonitoring.Body"
            android:textColor="@color/text_secondary"
            android:drawableTop="@android:drawable/ic_menu_search"
            android:drawablePadding="@dimen/spacing_medium"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
