<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điều khiển vòi phun"
                style="@style/TextAppearance.SmartFireMonitoring.Hero" />
        </LinearLayout>

        <!-- Mode Switch Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            style="@style/Widget.SmartFireMonitoring.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvAutoLock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang ở chế độ AUTO"
                            style="@style/TextAppearance.SmartFireMonitoring.Body"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_4"
                            android:text="Bật Manual để điều khiển tay"
                            style="@style/TextAppearance.SmartFireMonitoring.Caption" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/primary"
                        app:trackTint="@color/info_soft" />
                </LinearLayout>

                <!-- Status Banners inside card -->
                <LinearLayout
                    android:id="@+id/fireLockBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@color/danger_soft"
                    android:padding="@dimen/spacing_12"
                    android:visibility="gone"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/stat_notify_error"
                        app:tint="@color/danger" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Cảnh báo: Đang có cháy!"
                        android:textColor="@color/danger"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Servo Control Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            style="@style/Widget.SmartFireMonitoring.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/card_padding"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điều hướng servo"
                    style="@style/TextAppearance.SmartFireMonitoring.Label"
                    android:layout_marginBottom="@dimen/spacing_24"/>

                <!-- Servo X -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvServoXValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Trục Ngang: 90°"
                        style="@style/TextAppearance.SmartFireMonitoring.Body"
                        android:textStyle="bold" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekBarServoX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:layout_marginBottom="@dimen/spacing_24"
                    android:max="180"
                    android:progress="90"
                    android:splitTrack="false"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progressTint="@color/primary"
                    android:thumbTint="@color/primary" />

                <!-- Servo Y -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvServoYValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Trục Đứng: 45°"
                        style="@style/TextAppearance.SmartFireMonitoring.Body"
                        android:textStyle="bold" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekBarServoY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:max="60"
                    android:progress="60"
                    android:splitTrack="false"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Actuator Buttons -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="false"
            android:layout_marginBottom="@dimen/spacing_24">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPump"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_columnWeight="1"
                android:layout_marginEnd="@dimen/spacing_8"
                android:text="Bơm"
                style="@style/Widget.SmartFireMonitoring.Button.Secondary"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuzzer"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_columnWeight="1"
                android:layout_marginStart="@dimen/spacing_8"
                android:text="Còi báo"
                style="@style/Widget.SmartFireMonitoring.Button.Secondary"
                android:textColor="@color/text_primary" />
        </GridLayout>

        <!-- Safety Warning -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            app:cardBackgroundColor="#F8FAFC"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border"
            app:cardCornerRadius="@dimen/card_corner_radius">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_16"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lưu ý: Chế độ Auto sẽ ưu tiên kích hoạt khi có cháy để bảo vệ thiết bị."
                    style="@style/TextAppearance.SmartFireMonitoring.Caption"
                    android:textAlignment="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
