<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Premium Card Style - Unified -->
    <style name="Widget.SmartFireMonitoring.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="android:minHeight">@dimen/card_min_height</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardUseCompatPadding">false</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.SmartFireMonitoring.Card.Compact" parent="Widget.SmartFireMonitoring.Card">
        <item name="android:minHeight">112dp</item>
    </style>

    <!-- Standardized Typography per Premium UI Specs -->
    <style name="TextAppearance.SmartFireMonitoring.Hero" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/text_size_h1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.ScreenTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_size_section</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_card_title</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.SensorValue" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textSize">@dimen/text_size_sensor</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.MutedBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Legacy Compatibility Mappings -->
    <style name="TextAppearance.SmartFireMonitoring.Title" parent="TextAppearance.SmartFireMonitoring.ScreenTitle" />
    <style name="TextAppearance.SmartFireMonitoring.ValueLarge" parent="TextAppearance.SmartFireMonitoring.SensorValue" />

    <!-- Premium Button Styles -->
    <style name="Widget.SmartFireMonitoring.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.SmartFireMonitoring.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SmartFireMonitoring.Button.Toggle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Navigation -->
    <style name="Widget.SmartFireMonitoring.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemIconSize">22dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.SmartFireMonitoring.BottomNavLabel</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.SmartFireMonitoring.BottomNavLabel</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.BottomNavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Backward-compatible alias used by existing layout refs -->
    <style name="TextAppearance.SmartFireMonitoring.BottomNav" parent="TextAppearance.SmartFireMonitoring.BottomNavLabel" />

    <!-- Inputs -->
    <style name="Widget.SmartFireMonitoring.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/button_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/button_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/button_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/button_corner_radius</item>
    </style>

    <style name="Widget.SmartFireMonitoring.StatusChip" parent="TextAppearance.SmartFireMonitoring.Label">
        <item name="android:paddingHorizontal">@dimen/spacing_12</item>
        <item name="android:paddingVertical">@dimen/spacing_4</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
