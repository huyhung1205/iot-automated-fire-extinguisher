<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.SmartFireMonitoring.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/title_text_size</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.ScreenTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/body_text_size</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/caption_text_size</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SmartFireMonitoring.BottomNav" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:maxLines">1</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.SmartFireMonitoring.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SmartFireMonitoring.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SmartFireMonitoring.FilterButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SmartFireMonitoring.InputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>
</resources>
