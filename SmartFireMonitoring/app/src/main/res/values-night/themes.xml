<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.SmartFireMonitoring" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colors (Night) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/danger</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:colorBackground">#0F172A</item>
        <item name="colorSurface">#1E293B</item>
        <item name="colorOnSurface">#F8FAFC</item>
        <item name="colorSurfaceVariant">#334155</item>
        <item name="colorOnSurfaceVariant">#94A3B8</item>
        <item name="colorOutline">#475569</item>

        <!-- Status Bar & Navigation Bar (Night) -->
        <item name="android:statusBarColor">#0F172A</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#0F172A</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Component Styles -->
        <item name="materialCardViewStyle">@style/Widget.SmartFireMonitoring.Card</item>
        <item name="bottomNavigationStyle">@style/Widget.SmartFireMonitoring.BottomNav</item>
    </style>
</resources>
